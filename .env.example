# Copy to .env.local (or .env) for local development. Do not commit secrets.

# Origin of the active CogniCare API (cognicare/backend). Used by the Vite dev
# proxy for /api and /uploads, and for production builds as API_BASE_URL prefix.
# Default in vite.config.js if unset: http://localhost:3000
VITE_BACKEND_ORIGIN=http://localhost:3000
